      "variable": "last_user_input",
      "validation": null,
      "options": [
        {"label": "Tingnan ang Services", "value": "services", "next": "node_services"},
        {"label": "Book Now", "value": "book", "next": "node_services"},
        {"label": "Shop Info", "value": "info", "next": "node_shop_info"}
