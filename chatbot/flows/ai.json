{
  "id": "default_flow",
  "name": "AI Based",
  "trigger_keywords": [
    "hello",
    "hi",
    "start",
    "hey"
  ],
  "suggested_action": {
      "type": "string",
      "enum": [
          "trigger_booking",
          "small_talk",
          "handoff",
          "none",
          "services",
          "book",
          "info",
          "location",
          "kwento"
      ]
  },
  "nodes": [
    {
      "id": "node_1",
      "message": "Yo boss, AutoBot 'to ng 1625 Auto Lab. Ano setup natin today?",
      "input_type": "text",
      "variable": "last_user_input",
      "next": "node_fetch_context"
    },
    {
      "id": "node_fetch_context",
      "message": "",
      "input_type": "none",
      "next": "node_ai_processing",
      "http_request": {
        "method": "GET",
        "url": "http://localhost:8000/api/services",
        "response_variable": "live_menu_data"
      }
    },
    {
      "id": "node_ai_processing",
      "message": "",
      "input_type": "none",
      "validation": null,
      "options": [],
      "next": "node_ai_router",
      "http_request": {
        "method": "POST",
        "url": "http://localhost:8300/ai/evaluate",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "user_message": "{last_user_input}",
          "kb_context": "{live_menu_data}"
        },
        "response_variable": "ai_response_object"
      },
      "normalize_skip": false,
      "payload_assign": {
        "ai_reply": "ai_response_object.message",
        "ai_intent": "ai_response_object.suggested_action"
      }
    },
    {
      "id": "node_ai_router",
      "message": "",
      "input_type": "none",
      "routing_rules": [
        {
          "condition": "{ai_intent} == book",
          "next": "node_services"
        },
        {
          "condition": "{ai_intent} == services",
          "next": "node_services"
        },
        {
          "condition": "{ai_intent} == info",
          "next": "node_shop_info"
        },
        {
          "condition": "{ai_intent} == human",
          "next": "node_handoff_prompt"
        }
      ],
      "next": "node_ai_listen"
    },
    {
      "id": "node_ai_listen",
      "message": "",
      "input_type": "text",
      "variable": "last_user_input",
      "next": "node_fetch_context"
    },
    {
      "id": "node_ai_fallback",
      "message": "Ay, sorry boss, parang di ko masyadong nakuha. 😅\n\nPwede mo bang i-rephrase o pumili sa menu sa ibaba?\n\nKung gusto mo magkwento o magtanong ng kahit ano, game ako!",
      "input_type": "quick_reply",
      "validation": null,
      "options": [
        {
          "label": "Book Service",
          "value": "book",
          "next": "node_services"
        },
        {
          "label": "View Services",
          "value": "services",
          "next": "node_services"
        },
        {
          "label": "Shop Info",
          "value": "info",
          "next": "node_shop_info"
        },
        {
          "label": "Kwentuhan Tayo",
          "value": "kwento",
          "next": "node_small_talk"
        },
        {
          "label": "Talk to Human",
          "value": "human",
          "next": "node_handoff_prompt"
        }
      ],
      "next": "node_ai_listen",
      "http_request": null,
      "normalize_skip": false,
      "payload_assign": null
    },
    {
      "id": "node_small_talk",
      "message": "Sige boss, kwentuhan muna tayo! 😄\n\nPwede kang mag-share ng kahit anong kwento—car stories, trip mo, o kahit anong random.\n\nKung gusto mo bumalik sa services, sabihin mo lang!",
      "input_type": "text",
      "variable": "last_user_input",
      "next": "node_fetch_context"
    },
    {
      "id": "node_shop_info",
      "message": "Nasa San Fernando, Pampanga kami, boss! 🚗\n\nNKKS Arcade, Krystal Homes, Brgy. Alasas.\nOpen kami Mon–Sat, 9am–6pm.\nContact: 0939 330 8263\n\nMay gusto ka pa bang malaman? Huwag mahiyang magtanong!",
      "input_type": "quick_reply",
      "validation": null,
      "options": [
        {
          "label": "View Services",
          "value": "services",
          "next": "node_services"
        },
        {
          "label": "Book Now",
          "value": "book",
          "next": "node_services"
        },
        {
          "label": "Wala na, salamat!",
          "value": "end",
          "next": "node_1"
        }
      ],
      "next": "node_1",
      "http_request": null,
      "normalize_skip": false,
      "payload_assign": null
    },
    {
      "id": "node_handoff_prompt",
