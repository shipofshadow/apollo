      "validation": null,
      "options": [],
      "next": "node_ai_fallback",
      "http_request": null,
      "normalize_skip": false,
      "payload_assign": null,
      "routing_rules": [
        {"condition": "{ai_intent} == 'services'", "next": "node_services"},
        {"condition": "{ai_intent} == 'book'", "next": "node_services"},
        {"condition": "{ai_intent} == 'location'", "next": "node_shop_info"},
        {"condition": "{ai_intent} == 'info'", "next": "node_shop_info"},
        {"condition": "{ai_intent} == 'fallback'", "next": "node_ai_fallback"}
