    {
      "id": "node_choose_service",
      "message": "Pindot ka lang ng service card button sa taas.",
      "input_type": "text",
      "variable": "service_id",
      "validation": {
        "type": "number",
        "error_message": "Boss, pili ka sa service cards sa taas o maglagay ng valid service ID."
      },
      "options": [],
      "next": "node_variants",
      "http_request": null,
