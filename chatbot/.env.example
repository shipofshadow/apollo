# ──────────────────────────────────────────────────────────────────────────────
# AutoBot Backend – environment variable reference
# Copy this file to .env and fill in the values for your deployment.
# ──────────────────────────────────────────────────────────────────────────────

# ---------------------------------------------------------------------------
# Database
# Defaults to a local SQLite file (autobot.db) when not set.
# For MySQL: mysql+pymysql://user:password@localhost/autobot
# For PostgreSQL: postgresql://user:password@localhost/autobot
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./autobot.db

# ---------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins for the browser CORS check.
# Use "*" (or leave blank) during local development only.
# In production, list every domain that will call the API.
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=https://mysite.com,https://otherwebsite.com

# ---------------------------------------------------------------------------
# JWT Authentication (shared with PHP backend)
# These MUST match the PHP backend values so the Python service can verify
# Bearer tokens issued by PHP.
# ---------------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=

# ---------------------------------------------------------------------------
# AI (used by /ai/evaluate)
# AI_PROVIDER: openai | gemini
# If provider API key is missing, endpoint falls back to deterministic rules.
# ---------------------------------------------------------------------------
AI_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback KB when admin settings KB is empty.
AUTOBOT_ADMIN_KB=

