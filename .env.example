# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the PHP backend server.
# All /api/* calls from the React app are proxied here.
# Development default: http://localhost:8000
# SMS – Twilio (optional – leave blank to skip SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

VITE_BACKEND_URL=http://localhost:8000
