# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the PHP backend server.
# All /api/* calls from the React app are proxied here.
# Development default: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Your Facebook Page URL for the embedded Page Plugin in the Social section.
# e.g. https://www.facebook.com/your.page.name
VITE_FB_PAGE_URL=https://www.facebook.com
