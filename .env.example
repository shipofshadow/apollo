# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the PHP backend server.
# All /api/* calls from the React app are proxied here.
# Development default: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Facebook Graph API Page Access Token (optional).
# Only needed if the Facebook feed / social proof section is enabled.
# Obtain from https://developers.facebook.com/ > Tools > Graph API Explorer.
# Grant the pages_read_engagement permission and generate a Page Access Token.
VITE_FB_ACCESS_TOKEN=your_page_access_token_here
