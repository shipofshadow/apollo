# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the PHP backend server.
# All /api/* calls from the React app are proxied here.
# Development default: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# Note: The Facebook Page Access Token belongs in backend/.env (FB_ACCESS_TOKEN),
# NOT here. Any secret set as VITE_* is embedded in the client-side JavaScript
# bundle and is publicly readable by anyone who visits the site.
