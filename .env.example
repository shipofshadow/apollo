# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Frontend environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the PHP backend server.
# All /api/* calls from the React app are proxied here.
# Development default: http://localhost:8000
VITE_BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Facebook OAuth – admin panel "Connect Facebook Page" feature
#
# VITE_FB_REDIRECT_URI must match one of the "Valid OAuth Redirect URIs"
# registered in your Facebook App (Facebook Login > Settings).
# It should be the URL of the admin panel in your deployed frontend.
#
# Development default: http://localhost:5173/admin
# Production example:  https://yourdomain.com/admin
# ---------------------------------------------------------------------------
VITE_FB_REDIRECT_URI=http://localhost:5173/admin
