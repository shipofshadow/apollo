# Facebook Graph API page access token.
# Obtain from https://developers.facebook.com/ > Tools > Graph API Explorer.
# Grant the pages_read_engagement permission and generate a Page Access Token.
#
# Copy this file to .env (never commit .env to version control).
FB_ACCESS_TOKEN=your_page_access_token_here

# Comma-separated list of origins allowed to call this API.
# Defaults to the Vite dev server if not set.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# How long (in seconds) to cache the first-page /api/posts response in memory.
# Reduces redundant Facebook API calls. Set to 0 to disable caching.
# Default: 60
CACHE_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# Database (MySQL / MariaDB)
# Leave DB_NAME empty to skip the database connection entirely.
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=apollo
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
