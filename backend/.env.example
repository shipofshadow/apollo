# ─────────────────────────────────────────────────────────────────────────────
# 1625 Auto Lab – Backend environment variables
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ---------------------------------------------------------------------------
# Facebook Graph API (optional – powers the social feed)
# Obtain from https://developers.facebook.com/ > Tools > Graph API Explorer.
# Grant the pages_read_engagement permission.
# ---------------------------------------------------------------------------
FB_ACCESS_TOKEN=your_page_access_token_here

# How long (seconds) to cache the /api/posts response in memory.
# Set to 0 to disable. Default: 60
CACHE_TTL_SECONDS=60

# ---------------------------------------------------------------------------
# CORS – comma-separated list of allowed origins
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---------------------------------------------------------------------------
# Application URL – used to build password-reset links in emails.
# Set this to your production frontend URL when deploying.
# ---------------------------------------------------------------------------
APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Database (MySQL / MariaDB)
# Leave DB_NAME empty to skip the database connection entirely.
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autolab
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---------------------------------------------------------------------------
# JWT (JSON Web Tokens)
# JWT_SECRET must be a long, random string – never commit the real value.
# JWT_ALGORITHM: HS256 | HS384 | HS512
# JWT_TTL: token lifetime in seconds (default 3600 = 1 hour)
# ---------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_TTL=3600

# ---------------------------------------------------------------------------
# Transactional email
# MAIL_FROM is required for all outbound notifications.
# MAIL_ADMIN receives admin-side booking notifications.
# ---------------------------------------------------------------------------
MAIL_FROM=noreply@1625autolab.com
MAIL_FROM_NAME=1625 Auto Lab
MAIL_ADMIN=admin@1625autolab.com

# SMTP (recommended for reliable delivery)
# Leave SMTP_HOST blank to fall back to PHP mail().
# SMTP_ENCRYPTION: tls | ssl | none
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_AUTH=true
SMTP_TIMEOUT=10

# ---------------------------------------------------------------------------
# CarAPI – vehicle make / model / trim data
# Sign up at https://carapi.app, create an API token/secret pair, and paste
# them below. Obtain credentials from the CarAPI dashboard.
# CARAPI_MAKES_TTL:  cache lifetime in seconds for makes  (default 86400 = 24 h)
# CARAPI_MODELS_TTL: cache lifetime in seconds for models (default 43200 = 12 h)
# ---------------------------------------------------------------------------
CARAPI_TOKEN=your_carapi_token_here
CARAPI_SECRET=your_carapi_secret_here
CARAPI_MAKES_TTL=86400
CARAPI_MODELS_TTL=43200

# ---------------------------------------------------------------------------
# Media uploads
# FILESYSTEM_DISK: local | s3 (Cloudflare R2 via S3-compatible API)
# UPLOAD_MAX_MB:   maximum allowed file size in megabytes (default 10)
# UPLOAD_BASE_URL: public base URL for uploaded files (local fallback only)
#                  e.g. https://yourdomain.com/storage/uploads
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local
UPLOAD_MAX_MB=10
UPLOAD_BASE_URL=http://localhost:8000/storage/uploads

# ---------------------------------------------------------------------------
# Cloudflare R2 (S3-compatible object storage) – optional
# Used when FILESYSTEM_DISK=s3
#
# R2_ACCOUNT_ID:       Your Cloudflare account ID (shown in the R2 dashboard URL).
# R2_ACCESS_KEY_ID:    R2 API token key   (create an R2 token with Object Read & Write).
# R2_SECRET_ACCESS_KEY: R2 API token secret.
# R2_BUCKET_NAME:      The R2 bucket name (e.g. chopaeng).
# R2_KEY_PREFIX:       Object-key prefix for all uploads (default: chopaeng/1625autolab).
# R2_PUBLIC_URL:       Public base URL for reading uploaded files.
#                      Use your R2 public bucket URL, R2.dev sub-domain, or custom domain.
#                      e.g. https://pub-xxxxxxxxxxxx.r2.dev
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=chopaeng
R2_KEY_PREFIX=chopaeng/1625autolab
R2_PUBLIC_URL=

# ---------------------------------------------------------------------------
# SMS (Twilio) – optional
# Leave blank to disable SMS notifications.
# These values are backend-only and must never be added to frontend env files.
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---------------------------------------------------------------------------
# Waitlist claim window
# Minutes a notified customer has to claim an opened slot.
# ---------------------------------------------------------------------------
WAITLIST_CLAIM_TTL_MINUTES=30

# ---------------------------------------------------------------------------
# Turnstile bypass (development only)
# Set true to skip server-side Turnstile verification locally.
# ---------------------------------------------------------------------------
TURNSTILE_BYPASS=false
