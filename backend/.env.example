# Facebook Graph API page access token.
# Obtain from https://developers.facebook.com/ > Tools > Graph API Explorer.
# Grant the pages_read_engagement permission and generate a Page Access Token.
#
# Copy this file to .env (never commit .env to version control).
FB_ACCESS_TOKEN=your_page_access_token_here

# Comma-separated list of origins allowed to call this API.
# Defaults to the Vite dev server if not set.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
