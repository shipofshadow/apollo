{
    "name": "apollo/backend",
    "description": "1625 Auto Lab – PHP backend",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.9",
        "nikic/fast-route": "^1.3",
        "firebase/php-jwt": "^7.0",
        "aws/aws-sdk-php": "^3.0",
        "car-api-team/carapi-php-sdk": "^2.0",
        "php-http/guzzle7-adapter": "^1.0"
    },
    "autoload": {
        "classmap": [
            "Engine/",
            "db/"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
