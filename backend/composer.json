{
    "name": "apollo/backend",
    "description": "Apollo Facebook Posts API – PHP backend",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.9",
        "nikic/fast-route": "^1.3",
        "firebase/php-jwt": "^7.0"
    },
    "autoload": {
        "classmap": [
            "Engine/",
            "db/"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
